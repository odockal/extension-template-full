{
  "name": "chaos-lab",
  "displayName": "Chaos Lab",
  "description": "Chaos engineering toolkit for Podman Desktop",
  "version": "0.1.0",
  "icon": "icon.png",
  "publisher": "you",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": ">=1.10.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chaos-lab.viewContainerUsage",
        "title": "Chaos Lab: View Container"
      },
      {
        "command": "chaos-lab.stopAll",
        "title": "Chaos Lab: Stop All Chaos"
      }
    ],
    "menus": {
      "dashboard/container": [
        {
          "command": "chaos-lab.viewContainerUsage",
          "title": "View Container (Chaos Lab)"
        }
      ]
    },
    "configuration": {
      "title": "Chaos Lab",
      "properties": {
        "chaos.machine.cpus": {
          "type": "number",
          "format": "cpu",
          "minimum": 1,
          "maximum": 16,
          "default": 2,
          "scope": "ContainerConnection",
          "description": "CPU(s)"
        },
        "chaos.machine.memory": {
          "type": "number",
          "format": "memory",
          "minimum": 536870912,
          "default": 2147483648,
          "maximum": 34359738368,
          "scope": "ContainerConnection",
          "description": "Memory"
        },
        "chaos.machine.diskSize": {
          "type": "number",
          "format": "diskSize",
          "default": 21474836480,
          "minimum": 10737418240,
          "maximum": 536870912000,
          "scope": "ContainerConnection",
          "description": "Disk size"
        },
        "chaos.factory.machine.name": {
          "type": "string",
          "default": "chaos-default",
          "scope": "ContainerProviderConnectionFactory",
          "description": "Name"
        },
        "chaos.factory.machine.cpus": {
          "type": "number",
          "format": "cpu",
          "default": 2,
          "minimum": 1,
          "maximum": 16,
          "scope": "ContainerProviderConnectionFactory",
          "description": "CPU(s)"
        },
        "chaos.factory.machine.memory": {
          "type": "number",
          "format": "memory",
          "default": 2147483648,
          "minimum": 536870912,
          "maximum": 34359738368,
          "scope": "ContainerProviderConnectionFactory",
          "description": "Memory"
        },
        "chaos.factory.machine.diskSize": {
          "type": "number",
          "format": "diskSize",
          "default": 21474836480,
          "minimum": 10737418240,
          "maximum": 536870912000,
          "scope": "ContainerProviderConnectionFactory",
          "description": "Disk size"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "lint:check": "eslint . --ext js,ts,tsx",
    "lint:fix": "eslint . --fix --ext js,ts,tsx",
    "watch": "vite --mode development build -w"
  },
  "devDependencies": {
    "@podman-desktop/api": "1.12.0",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^8.56.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-sonarjs": "^1.0.4",
    "prettier": "^3.3.3",
    "typescript": "5.5.4",
    "vite": "8.0.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {}
}
